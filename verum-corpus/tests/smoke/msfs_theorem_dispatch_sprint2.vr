// =============================================================================
// §8 Three Standard Bypass Paths — Theorems 8.1–8.8
// =============================================================================

@test
fn test_bypass_universe_polymorphism_8_1_reachable() {
    let _: fn(&LAbsCandidate) = msfs_theorem_8_1_universe_polymorphism;
    assert(true, "Theorem 8.1 universe-polymorphism reachable");
}

@test
fn test_bypass_reflective_tower_8_2_reachable() {
    let _: fn(&LAbsCandidate) = msfs_theorem_8_2_reflective_tower;
    assert(true, "Theorem 8.2 reflective-tower reachable");
}

@test
fn test_bypass_definitions_8_3_8_5_axioms() {
    assert(msfs_definition_8_3_display_class(),
           "Definition 8.3 — display class");
    assert(msfs_definition_8_4_display_2_category(),
           "Definition 8.4 — display 2-category");
    assert(msfs_definition_8_5_s_int(),
           "Definition 8.5 — S_int");
}

@test
fn test_bypass_intensional_path_8_6_8_8_axioms() {
    assert(msfs_theorem_8_6_I_existence(),
           "Theorem 8.6 — I : F^op → S_int existence");
    assert(msfs_theorem_8_7_slice_locality(),
           "Theorem 8.7 — slice-locality of I");
    let _: fn(&LAbsCandidate) = msfs_corollary_8_8_intensional_no_new_axis;
    assert(true, "Corollary 8.8 — intensional gives no new axis");
}

