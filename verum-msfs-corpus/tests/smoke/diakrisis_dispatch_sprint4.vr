    diakrisis_axi_6_rho_M_non_commute,
    diakrisis_axi_7_self_articulability,
    diakrisis_axi_8_alpha_M_non_LP_representable,
    diakrisis_axi_9_ac_oc_biadjunction_premise,
    diakrisis_T_alpha_depth_function,
    diakrisis_T_2f_star_comprehension_stratification,
    diakrisis_T_2f_star_star,
};

