@test
fn test_diakrisis_d4_intensional_path_100_to_102() {
    assert(diakrisis_theorem_100_T_I_existence(),
           "100.T — I existence");
    assert(diakrisis_100_T_msfs_8_6_correspondence(),
           "100.T ↔ MSFS Theorem 8.6");
    assert(diakrisis_theorem_101_T_slice_locality(),
           "101.T — slice locality");
    assert(diakrisis_101_T_msfs_8_7_correspondence(),
           "101.T ↔ MSFS Theorem 8.7");
    let _: fn(&LAbsCandidate) = diakrisis_theorem_102_T_intensional_no_new_axis;
    assert(diakrisis_102_T_msfs_8_8_correspondence(),
           "102.T ↔ MSFS Corollary 8.8");
}

// =============================================================================
// D.5 — Maximality (103.T through 106.T): Diakrisis ∈ L_Cls^top
// =============================================================================

@test
fn test_diakrisis_d5_universal_articulation_103_T() {
    // 103.T is the FLAGSHIP maximality theorem: a universal
    // articulation exists (closing MSFS open question Q1).
    assert(diakrisis_theorem_103_T_universal_articulation(),
           "103.T — universal articulation (Q1 closure)");
    assert(diakrisis_103_T_msfs_q1_closure(),
           "103.T → MSFS Q1 closure correspondence");
}

@test
fn test_diakrisis_d5_uniqueness_104_T() {
    assert(diakrisis_theorem_104_T_uniqueness(),
           "104.T — uniqueness up to Morita");
    assert(diakrisis_104_T_msfs_9_3_correspondence(),
           "104.T ↔ MSFS Theorem 9.3");
}

@test
fn test_diakrisis_d5_yanofsky_immunity_105_T() {
    // 105.T — Yanofsky-universal immunity via depth-stratification
    // (the Diakrisis kernel rule the VVA imports as K-Refine).
    assert(diakrisis_theorem_105_T_yanofsky_immunity(),
           "105.T — Yanofsky-universal immunity (depth-stratified)");
    assert(diakrisis_105_T_kernel_K_refine_ground(),
           "105.T → K-Refine kernel-rule ground");
}

@test
fn test_diakrisis_d5_in_l_cls_top_106_T() {
    // FLAGSHIP: 106.T establishes Diakrisis ∈ L_Cls^top — the
    // structural witness that L_Cls^top is non-empty (a fact
    // Theorem 11.1 cites for Cor. 5.2's vacuous strictness).
    assert(diakrisis_theorem_106_T_diakrisis_in_l_cls_top(),
           "106.T — Diakrisis ∈ L_Cls^top");
    assert(diakrisis_106_T_l_cls_top_nonempty(),
           "106.T corollary — L_Cls^top non-empty");
}

