// =============================================================================
// D.1 — Canonical Primitive (13 axioms)
// =============================================================================

@test
fn test_diakrisis_d1_axi_0_through_2() {
    assert(diakrisis_axi_0_non_empty(),                 "Axi-0 — M is non-empty");
    assert(diakrisis_axi_1_internal_closure(),          "Axi-1 — internal closure");
    assert(diakrisis_axi_2_M_is_2_functor(),            "Axi-2 — M is 2-functor");
}

@test
fn test_diakrisis_d1_axi_3_through_6() {
    assert(diakrisis_axi_3_alpha_math_exists(),          "Axi-3 — α_math exists");
    assert(diakrisis_axi_4_rho_internal_hom(),           "Axi-4 — ρ via internal hom");
    assert(diakrisis_axi_5_rho_nontrivial(),             "Axi-5 — ρ non-trivial");
    assert(diakrisis_axi_6_rho_M_non_commute(),          "Axi-6 — ρ ∘ M ≠ M ∘ ρ");
}

@test
fn test_diakrisis_d1_axi_7_through_9() {
    assert(diakrisis_axi_7_self_articulability(),         "Axi-7 — self-articulability");
    assert(diakrisis_axi_8_alpha_M_non_LP_representable(),"Axi-8 — α_M non-LP-rep");
    // Axi-9: AC/OC biadjunction premise — the bridge to MSFS §10 Theorem 10.4.
    assert(diakrisis_axi_9_ac_oc_biadjunction_premise(),  "Axi-9 — AC/OC biadjunction");
}

@test
fn test_diakrisis_d1_T_alpha_and_T_2f_star() {
    // T-α (depth function) + T-2f* (depth-stratified comprehension)
    // are the load-bearing rules the VVA kernel imports as K-Refine.
    assert(diakrisis_T_alpha_depth_function(),
           "T-α — depth function dp");
    assert(diakrisis_T_2f_star_comprehension_stratification(),
           "T-2f* — depth-stratified comprehension (K-Refine)");
    assert(diakrisis_T_2f_star_star(),
           "T-2f** — universe ascent rule");
}

// =============================================================================
// D.2 — Foundational Architecture (theorems 10.T through 28.T sample)
// =============================================================================

@test
fn test_diakrisis_d2_foundational_10_to_15() {
    assert(diakrisis_theorem_10_T_locally_small(),   "10.T — M locally small");
    assert(diakrisis_theorem_11_T_internal_closure(),"11.T — internal closure");
    assert(diakrisis_theorem_12_T_iota_existence(),  "12.T — ι existence");
    assert(diakrisis_theorem_13_T_M_2_functor(),     "13.T — M is 2-functor");
    assert(diakrisis_theorem_14_T_alpha_M_canonical(),"14.T — α_M canonical");
    assert(diakrisis_theorem_14_T2_axi_8_witness(), "14.T₂ — Axi-8 witness");
    assert(diakrisis_theorem_15_T_M_naturality(),    "15.T — M naturality");
}

@test
fn test_diakrisis_d2_iota_properties_16_to_19() {
    assert(diakrisis_theorem_16_T_iota_faithful(),
           "16.T — ι faithful");
    // Theorem 16.T10 — the canonicalisation round-trip. Preprint-
    // blocked at kernel-level reconstruction (VVA §A.Z.5 item 6).
    // Anchored here at the corpus reachability layer.
    assert(diakrisis_theorem_16_T10_round_trip(),
           "16.T10 — round-trip (canonicalize ∘ ι ≅ id, preprint-blocked)");
    assert(diakrisis_16_T10_kernel_K_round_trip_ground(),
           "16.T10 kernel ground — K-Round-Trip rule citation");
    assert(diakrisis_theorem_17_T_iota_full_mod_gauge(),
           "17.T — ι full mod gauge");
    assert(diakrisis_theorem_17_T1_effect_kleisli(),
           "17.T₁ — effect Kleisli structure");
    assert(diakrisis_theorem_18_T_image_characterization(),
           "18.T — image characterization");
    assert(diakrisis_theorem_19_T_yoneda_compatible(),
           "19.T — Yoneda compatible");
}

@test
fn test_diakrisis_d2_iota_extensions_20_to_28() {
    assert(diakrisis_theorem_20_T_iota_infty_n_extension(),
           "20.T — ι (∞,n)-extension");
    assert(diakrisis_theorem_21_T_iota_monoidal(),
           "21.T — ι monoidal");
    assert(diakrisis_theorem_21_T2_stack_model_precursor(),
           "21.T₂ — stack-model precursor");
    assert(diakrisis_theorem_22_T_image_M_stable(),
           "22.T — image M-stable");
    assert(diakrisis_theorem_23_T_shape_left_adjoint(),
           "23.T — shape left-adjoint (cohesive ∫)");
    assert(diakrisis_theorem_24_T_flat_sharp_adjunction(),
           "24.T — flat-sharp adjunction (♭ ⊣ ♯)");
    assert(diakrisis_theorem_25_T_crisp_collapse(),
           "25.T — crisp collapse");
    assert(diakrisis_theorem_26_T_dcct_ground(),
           "26.T — DCCT ground");
    assert(diakrisis_theorem_27_T_grothendieck_fibration(),
           "27.T — Grothendieck fibration");
    assert(diakrisis_theorem_28_T_fiber_equivalence_classes(),
           "28.T — fiber equivalence classes");
}

