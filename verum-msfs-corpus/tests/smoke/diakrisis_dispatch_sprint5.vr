// =============================================================================
// Diakrisis dispatch smoke — Sprint 5 (#204): D.7 + D.8 + D.9 + D.10 + research
// =============================================================================
//
// Closes the entire Diakrisis dispatch matrix at 10 of 10 stages (100%).
//
//   D.7 Аktica (12_actic/actica_107_to_127.vr) — Theorems 107.T-127.T
//        covering the AC/OC duality machinery: 108.T (Morita duality
//        — preprint-blocked at kernel reconstruction), 109.T (dual
//        no-go), 124.T (biadjunction witness), 125.T (universal pair),
//        126.T (gauge α-projection), 127.T (Аktica completeness).
//        Each cited theorem ships with an _msfs_correspondence axiom
//        bridging it to the MSFS §10 / §11 counterpart.
//
//   D.8 Аktica extended (12_actic/actica_138_to_141.vr) — Theorems
//        138.T-141.T covering dual gauge kernel, dual primitive
//        initial, (∞,∞)-invariant, constructive autopoiesis.
//
//   D.9 Operational coherence (research_extensions/operational_coherence.vr)
//        — Theorems 18.T₁ (α-ε duality), 18.T₂ (finite decidability),
//        18.T₃ (corpus coherence) + Verum coherent ground + audit
//        coherent gate.
//
//   D.10 UHM articulation (research_extensions/uhm_articulation.vr)
//        — UHM T₁/T₂/T₃/T₄ establishing UHM ∈ L_Cls^top with
//        ε(UHM) at ω³+1, path-b baseline, plus MSFS L_Cls^top
//        witness corollary + noesis 223 path-b anchor.
//
//   Research (research_extensions/research_136_137_142.vr) —
//        Theorems 136.T (T-2f**), 137.T (weak AFN-T), 142.T (eastern
//        non-classical) plus kernel-rule grounds (K-Refine-omega,
//        VVA-8 ground) + MSFS B.2 correspondence.
//
// After Sprint 5 the corpus dispatch matrix covers 24 of 24 sections
// (MSFS 14 + Diakrisis 10 = 24, 100%).
// =============================================================================

module tests.smoke.diakrisis_dispatch_sprint5;

// D.7 Аktica
mount lib.theorems.diakrisis.actica.{
    diakrisis_theorem_107_T_relative_consistency,
    diakrisis_theorem_108_T_ac_oc_morita_duality,
    diakrisis_108_T_msfs_10_4_correspondence,
    diakrisis_theorem_109_T_dual_no_go,
    diakrisis_109_T_msfs_10_7_correspondence,
    diakrisis_theorems_110_to_120,
    diakrisis_theorems_121_to_123,
    diakrisis_theorem_124_T_biadjunction_witness,
    diakrisis_124_T_msfs_10_4_step_c_correspondence,
    diakrisis_theorem_125_T_universal_pair,
    diakrisis_theorem_126_T_gauge_alpha_projection,
    diakrisis_theorem_127_T_actica_completeness,
};

