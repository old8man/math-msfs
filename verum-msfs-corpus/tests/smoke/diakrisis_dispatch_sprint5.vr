// =============================================================================
// Research Extensions — 136.T / 137.T / 142.T
// =============================================================================

@test
fn test_research_t_2f_star_star_star_136_T() {
    // 136.T — T-2f*** (omega-iterated depth-stratified
    // comprehension). Together with 105.T's T-2f* and 131.T's
    // T-2f**, gives the full kernel-rule ladder:
    //   T-2f*    →  K-Refine
    //   T-2f**   →  K-Universe-Ascent
    //   T-2f***  →  K-Refine-omega
    assert(diakrisis_theorem_136_T_t_2f_star_star_star(),
           "136.T — T-2f*** (ω-iterated depth-stratification)");
    assert(diakrisis_136_T_kernel_K_refine_omega_ground(),
           "136.T → K-Refine-omega kernel-rule ground");
}

@test
fn test_research_weak_afnt_137_T() {
    // 137.T — weak AFN-T. Closes MSFS Q5 with VVA-8 ground.
    assert(diakrisis_theorem_137_T_weak_afnt(),
           "137.T — weak AFN-T");
    assert(diakrisis_137_T_msfs_q5_kernel_vva_8_ground(),
           "137.T → MSFS Q5 closure + VVA-8 kernel ground");
}

@test
fn test_research_eastern_non_classical_142_T() {
    // 142.T — eastern non-classical extension. AFN-T survives
    // intuitionistic + paraconsistent + relevance variations.
    assert(diakrisis_theorem_142_T_eastern_non_classical(),
           "142.T — eastern non-classical (intuit + paracon + rel)");
    assert(diakrisis_142_T_msfs_b_2_correspondence(),
           "142.T ↔ MSFS Theorem B.2 (paraconsistent AFN-T)");
}
