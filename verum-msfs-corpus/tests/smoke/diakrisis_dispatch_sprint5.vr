// =============================================================================
// D.9 Operational Coherence — Theorems 18.T₁/T₂/T₃ + grounds
// =============================================================================

@test
fn test_operational_coherence_alpha_epsilon_duality_18_T1() {
    // 18.T₁ — α-ε duality at the operational level + Verum-coherent
    // ground (the gate `verum audit --coherent` enforces).
    assert(diakrisis_theorem_18_T1_alpha_epsilon_duality(),
           "18.T₁ — α-ε duality (operational)");
    assert(diakrisis_18_T1_verum_coherent_ground(),
           "18.T₁ → Verum coherent ground (audit gate)");
}

@test
fn test_operational_coherence_finite_decidability_18_T2() {
    // 18.T₂ — finite-axiomatisation case is decidable. Distinct
    // from the lurie_htt / schreiber_dcct semi-decidable case.
    assert(diakrisis_theorem_18_T2_finite_decidability(),
           "18.T₂ — finite-axiomatisation decidability");
}

@test
fn test_operational_coherence_corpus_coherence_18_T3() {
    // 18.T₃ — corpus coherence: every (Fw, ν, τ) coordinate in
    // the corpus is coherent under α-ε round-trip + audit gate.
    assert(diakrisis_theorem_18_T3_corpus_coherence(),
           "18.T₃ — corpus coherence");
    assert(diakrisis_18_T3_audit_coherent_gate(),
           "18.T₃ → audit-coherent gate (verum audit --coherent)");
}

