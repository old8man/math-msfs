}

@test
fn test_uhm_epsilon_omega3_plus_1_T2() {
    // UHM T₂ — UHM articulation depth ε at ω³ + 1.
    assert(diakrisis_theorem_uhm_T2_epsilon_omega3_plus_1(),
           "UHM T₂ — ε(UHM) = ω³ + 1");
}

@test
fn test_uhm_path_b_baseline_T3() {
