// =============================================================================
// D.7 Аktica — Theorems 107.T through 127.T
// =============================================================================

@test
fn test_actica_relative_consistency_107_T() {
    assert(diakrisis_theorem_107_T_relative_consistency(),
           "107.T — relative consistency (AC/OC sound w.r.t. Diakrisis foundation)");
}

@test
fn test_actica_morita_duality_108_T() {
    // FLAGSHIP: 108.T — AC/OC Morita duality. Preprint-blocked at
    // kernel-level reconstruction (VVA §A.Z.5 item 6); anchored at
    // reachability + bridged to MSFS Theorem 10.4.
    assert(diakrisis_theorem_108_T_ac_oc_morita_duality(),
           "108.T — AC/OC Morita duality (preprint-blocked)");
    assert(diakrisis_108_T_msfs_10_4_correspondence(),
           "108.T ↔ MSFS Theorem 10.4");
}

@test
fn test_actica_dual_no_go_109_T() {
    // 109.T — dual no-go (Dual-AFN-T). DC-side analogue of MSFS
    // Theorem 10.7's Dual Boundary Lemma.
    assert(diakrisis_theorem_109_T_dual_no_go(),
           "109.T — dual no-go (Dual-AFN-T)");
    assert(diakrisis_109_T_msfs_10_7_correspondence(),
           "109.T ↔ MSFS Theorem 10.7");
}

@test
fn test_actica_extension_block_110_to_123() {
    assert(diakrisis_theorems_110_to_120(),
           "110.T-120.T extension block (Аktica internal lemmata)");
    assert(diakrisis_theorems_121_to_123(),
           "121.T-123.T extension block (gauge group machinery)");
}

@test
fn test_actica_biadjunction_witness_124_T() {
    // 124.T — biadjunction witness (the constructive instance of
    // the AC ↔ OC biadjunction whose existence Axi-9 axiomatised).
    assert(diakrisis_theorem_124_T_biadjunction_witness(),
           "124.T — biadjunction witness (Axi-9 inhabitant)");
    assert(diakrisis_124_T_msfs_10_4_step_c_correspondence(),
           "124.T ↔ MSFS Theorem 10.4 step (c)");
}

@test
fn test_actica_universal_pair_and_gauge_125_to_127_T() {
    assert(diakrisis_theorem_125_T_universal_pair(),
           "125.T — universal AC/OC pair");
    assert(diakrisis_theorem_126_T_gauge_alpha_projection(),
           "126.T — gauge α-projection");
    assert(diakrisis_theorem_127_T_actica_completeness(),
           "127.T — Аktica completeness");
}

