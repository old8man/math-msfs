// =============================================================================
// Appendix B — Paraconsistent Extension
// =============================================================================

@test
fn test_app_b_definition_B_1_paraconsistent() {
    assert(msfs_definition_B_1_paraconsistent_rich_s(),
           "Definition B.1 — paraconsistent RichS (LP-style)");
}

@test
fn test_app_b_theorem_B_2_paraconsistent_afnt() {
    // Theorem B.2 — AFN-T survives the paraconsistent generalization.
    // The conjunction (F_S) ∧ (Π_4) ∧ (Π_3-max) remains internally
    // inconsistent even when underlying logic is paraconsistent.
    assert(msfs_theorem_B_2_paraconsistent_afnt(),
           "Theorem B.2 — paraconsistent AFN-T");
}
